def render_mini_chart(symbol: str, height: int = 70):
    """Sparkline of recent ticks — uses display-converted history."""
    import streamlit as st
    import streamlit.components.v1 as components
    from src.streaming.price_store import price_store

    # Get live USDINR
    usdinr = price_store.get("USDINR", fallback=True) or 92.99
    history = price_store.get_history_display(symbol, usdinr, n=60)

    if len(history) < 2:
        st.caption(f"Waiting for {symbol} ticks...")
        return

    prices = [round(p, 2) for _, p in history]
    times  = [t.strftime("%H:%M:%S") for t, _ in history]
    is_up  = prices[-1] >= prices[0]
    color  = "#00cc66" if is_up else "#ff4444"

    html = f"""
<canvas id="spark-{symbol}" width="300" height="{height}" style="width:100%;display:block"></canvas>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
(function() {{
    const ctx = document.getElementById("spark-{symbol}").getContext("2d");
    new Chart(ctx, {{
        type: "line",
        data: {{
            labels: {json.dumps(times)},
            datasets: [{{
                data: {json.dumps(prices)},
                borderColor: "{color}",
                borderWidth: 1.5,
                pointRadius: 0,
                fill: true,
                backgroundColor: "{color}22",
                tension: 0.3,
            }}]
        }},
        options: {{
            animation: false,
            plugins: {{ legend: {{ display: false }} }},
            scales: {{ x: {{ display:false }}, y: {{ display:false }} }},
        }}
    }});
}})();
</script>
"""
    components.html(html, height=height + 5, scrolling=False)


def render_connection_status():
    import streamlit as st
    from src.streaming.tick_engine import tick_engine
    stats = tick_engine.stats()
    if stats["connected"]:
        st.markdown(
            f'<span style="color:#00cc66;font-size:12px">● LIVE</span> '
            f'<span style="color:#555;font-size:11px">{stats.get("prices_cached",0)} symbols</span>',
            unsafe_allow_html=True,
        )
    elif not stats.get("enabled", False):
        st.markdown(
            '<span style="color:#4da3ff;font-size:12px">● RECONNECTING</span> '
            '<span style="color:#555;font-size:11px">prices from yfinance</span>',
            unsafe_allow_html=True,
        )
    else:
        st.markdown(
            f'<span style="color:#ffaa00;font-size:12px">● RECONNECTING</span> '
            f'<span style="color:#555;font-size:11px">attempt {stats.get("reconnects",0)}</span>',
            unsafe_allow_html=True,
        )


