# trading-agent/src/streaming/live_ticker.py
"""
Live Ticker — real-time price display that updates every second via JS polling.

KEY FIX: The JS formatPrice() function now uses the EXACT SAME formulas
as Python's convert_price() in price_store.py. Both read from the same
price_store (raw yfinance prices) and apply identical conversions.

This eliminates the ticker≠tile discrepancy.

Architecture:
  1. Background thread (PriceStore) fetches prices via yfinance every 10s
  2. Angel One WebSocket (TickEngine) pushes live NSE prices
  3. Flask server (port 8502) serves /prices as JSON
  4. JS in Streamlit polls /prices every 1s and updates DOM directly
  5. Python metric tiles call price_store.get_display() — same data, same math
"""
import threading
import json
from loguru import logger

PRICE_SERVER_PORT = 8502
_server_started   = False
_server_lock      = threading.Lock()


# ── Flask price server ────────────────────────────────────────────────────────

def start_price_server():
    global _server_started
    with _server_lock:
        if _server_started:
            return
        _server_started = True

    thread = threading.Thread(target=_run_flask, daemon=True, name="PriceServer")
    thread.start()
    logger.info(f"Price server started on port {PRICE_SERVER_PORT}")


def _run_flask():
    try:
        from flask import Flask, jsonify, request
        from flask_cors import CORS
    except ImportError:
        logger.error("pip install flask flask-cors")
        return

    from src.streaming.price_store import price_store, ACTIVE_EXPIRY, PRICE_META
    from src.streaming.tick_engine import tick_engine

    app = Flask("price_server")
    CORS(app)

    @app.route("/prices")
    def prices():
        """
        Returns raw prices + metadata. JS does the conversion.
        Format: {
          "prices": {
            "GOLD": {
              "raw": 3300.0,       ← raw yfinance value (USD/oz)
              "age_sec": 4.2,
              "stale": false,
              "live": true,
              "convert": "gold",   ← tells JS which formula to use
              "label": "/10g",     ← display suffix
              "expiry": "Jun 2026" ← MCX contract expiry if applicable
            }
          },
          "usdinr": 92.99,         ← live USDINR for JS conversions
          "store_stats": {...}
        }
        """
        all_px = price_store.get_all()
        stats  = price_store.stats()

        # Get live USDINR for JS
        usdinr = price_store.get("USDINR", fallback=True) or 92.99

        from src.data.models import (
            NSE_SYMBOLS, MCX_SYMBOLS, CRYPTO_SYMBOLS, FOREX_SYMBOLS
        )
        try:
            from src.streaming.tick_engine import STREAM_SYMBOLS
            exposed = (
                set(STREAM_SYMBOLS.keys())
                | set(NSE_SYMBOLS.keys())
                | set(MCX_SYMBOLS.keys())
                | set(CRYPTO_SYMBOLS.keys())
                | set(FOREX_SYMBOLS.keys())
            )
        except Exception:
            exposed = set(all_px.keys())

        result = {}
        for sym in exposed:
            px    = all_px.get(sym) or price_store.get(sym, fallback=False)
            age   = price_store.age_seconds(sym)
            meta  = PRICE_META.get(sym, {"convert": "usd_to_inr", "label": ""})
            result[sym] = {
                "raw":    px,
                "age_sec":round(age, 1) if age is not None else None,
                "stale":  price_store.is_stale(sym),
                "live":   tick_engine.is_connected(),
                "convert":meta.get("convert", "usd_to_inr"),
                "label":  meta.get("label", ""),
                "note":   meta.get("note", ""),
                "expiry": ACTIVE_EXPIRY.get(sym, ""),
            }

        return jsonify({
            "prices":      result,
            "usdinr":      usdinr,
            "store_stats": stats,
        })

    @app.route("/health")
    def health():
        from src.streaming.tick_engine import tick_engine
        return jsonify({
            "tick_engine": tick_engine.stats(),
            "price_store": price_store.stats(),
        })

    @app.route("/advice")
    def advice():
        try:
            from src.analysis.realtime_advisor import realtime_advisor
            return jsonify({"advice": realtime_advisor.get_all()})
        except Exception:
            return jsonify({"advice": {}})

    @app.route("/chart-context", methods=["GET", "POST"])
    def chart_context():
        try:
            from src.analysis.realtime_advisor import realtime_advisor
            if request.method == "POST":
                payload = request.get_json(silent=True) or {}
                return jsonify(realtime_advisor.update_chart_context(payload))
            return jsonify({"context": realtime_advisor.get_chart_context()})
        except Exception:
            return jsonify({"context": {}})

    import logging
    logging.getLogger("werkzeug").setLevel(logging.ERROR)
    app.run(host="0.0.0.0", port=PRICE_SERVER_PORT, threaded=True)


# ── JS conversion engine ───────────────────────────────────────────────────────
# Must be kept in sync with convert_price() in price_store.py

JS_FORMAT_FUNCTION = """
function formatPrice(sym, raw, convertType, label, usdinr) {
    if (raw === null || raw === undefined || raw <= 0) return "—";
    let p = parseFloat(raw);
    let u = parseFloat(usdinr) || 92.99;
    let val;

    switch(convertType) {
        case 'none':
            val = p;
            break;
        case 'usd_to_inr':
            val = p * u;
            break;
        case 'gold':
            // USD/troy oz → INR per 10 grams
            val = p * u * 10 / 31.1035;
            break;
        case 'silver':
            // USD/troy oz → INR per kg
            val = p * u * 1000 / 31.1035;
            break;
        case 'copper':
        case 'zinc':
            // USD/lb → INR/kg
            val = p * u / 0.453592;
            break;
        default:
            val = p * u;
    }

    // Format the number
    let formatted;
    const indices = ["NIFTY50","BANKNIFTY","SENSEX","NIFTYMID","NIFTYIT",
                     "FINNIFTY","NIFTYPHARMA","NIFTYAUTO","NIFTYFMCG","NIFTYINFRA"];
    const forex   = ["USDINR","EURINR","GBPINR","JPYINR"];
    const fxusd   = ["EURUSD","GBPUSD"];

    if (indices.includes(sym)) {
        formatted = val.toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2});
    } else if (forex.includes(sym)) {
        formatted = "₹" + val.toFixed(4);
    } else if (fxusd.includes(sym)) {
        formatted = "$" + val.toFixed(4);
    } else if (val >= 10000000) {
        formatted = "₹" + (val/100000).toFixed(2) + "L";
    } else if (val >= 1000) {
        formatted = "₹" + Math.round(val).toLocaleString('en-IN');
    } else {
        formatted = "₹" + val.toFixed(2);
    }

    return formatted + (label || "");
}
"""


# ── Streamlit render functions ────────────────────────────────────────────────

def render_live_ticker(
    symbols: list[str],
    usdinr:  float = 92.99,
    height:  int   = 95,
):
    """
    Renders a live price ticker bar updating every 1s via JS.
    JS receives raw prices + convert type from /prices endpoint.
    Uses identical conversion math as Python — no more ticker≠tile mismatch.
    """
    import streamlit.components.v1 as components
    from src.streaming.price_store import ACTIVE_EXPIRY, PRICE_META

    ticker_items = []
    for sym in symbols:
        expiry = ACTIVE_EXPIRY.get(sym, "")
        expiry_html = f'<span class="ticker-expiry">{expiry}</span>' if expiry else ""
        ticker_items.append(f"""
        <div class="ticker-item" id="ticker-{sym}">
            <div class="ticker-top">
                <span class="ticker-sym">{sym}</span>
                {expiry_html}
            </div>
            <span class="ticker-price" id="price-{sym}">—</span>
            <span class="ticker-age"  id="age-{sym}"></span>
        </div>""")

    sym_list_js = json.dumps(symbols)

    html = f"""
<style>
body {{ margin:0; background:transparent; font-family:'Segoe UI',sans-serif; }}
.ticker-bar {{
    display:flex; flex-wrap:wrap; gap:5px; padding:5px 0;
}}
.ticker-item {{
    background:#0f1724;
    border:1px solid #1f2937;
    border-left:3px solid #1f2937;
    border-radius:7px;
    padding:5px 10px;
    min-width:120px;
    transition:border-color 0.3s;
}}
.ticker-item.live  {{ border-left-color:#00cc66; }}
.ticker-item.stale {{ border-left-color:#ff4444; }}
.ticker-top {{ display:flex; justify-content:space-between; align-items:center; }}
.ticker-sym    {{ font-size:10px; color:#6b7280; font-weight:700; text-transform:uppercase; }}
.ticker-expiry {{ font-size:8px; color:#374151; }}
.ticker-price  {{ font-size:14px; font-weight:700; color:#f3f4f6; margin:2px 0; display:block; transition:color 0.5s; }}
.ticker-age    {{ font-size:9px; color:#4b5563; }}
</style>
<div class="ticker-bar" id="ticker-bar">
{''.join(ticker_items)}
</div>
<script>
{JS_FORMAT_FUNCTION}

const symbols  = {sym_list_js};
const priceUrl = "http://localhost:{PRICE_SERVER_PORT}/prices";
let prevPrices = {{}};
let liveUSDINR = {usdinr};

async function fetchAndUpdate() {{
    try {{
        const res  = await fetch(priceUrl, {{cache:"no-store"}});
        const data = await res.json();
        const px   = data.prices || {{}};
        liveUSDINR = data.usdinr || liveUSDINR;

        for (const sym of symbols) {{
            const info  = px[sym] || {{}};
            const raw   = info.raw;
            const age   = info.age_sec;
            const stale = info.stale;
            const conv  = info.convert || "none";
            const label = info.label   || "";

            const priceEl = document.getElementById("price-" + sym);
            const ageEl   = document.getElementById("age-"   + sym);
            const itemEl  = document.getElementById("ticker-" + sym);
            if (!priceEl) continue;

            const display = formatPrice(sym, raw, conv, label, liveUSDINR);
            priceEl.textContent = display;

            // Flash animation on price change
            if (prevPrices[sym] !== undefined && raw !== null) {{
                if      (raw > prevPrices[sym]) {{ priceEl.style.color="#00cc66"; setTimeout(()=>priceEl.style.color="#f3f4f6",600); }}
                else if (raw < prevPrices[sym]) {{ priceEl.style.color="#ff4444"; setTimeout(()=>priceEl.style.color="#f3f4f6",600); }}
            }}
            if (raw !== null) prevPrices[sym] = raw;

            if (age !== null) {{
                const dot = stale ? "🔴" : "🟢";
                ageEl.textContent = age < 60 ? age.toFixed(0) + "s ago" : "stale";
            }}
            if (itemEl) itemEl.className = "ticker-item " + (stale ? "stale" : "live");
        }}
    }} catch(e) {{
        // price server not yet ready
    }}
}}

fetchAndUpdate();
setInterval(fetchAndUpdate, 1000);
</script>
"""
    components.html(html, height=height, scrolling=False)


