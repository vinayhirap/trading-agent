    lat = features_df.iloc[-1].to_dict()
    result = {
        "sym":          sym,
        "price":        float(df["close"].iloc[-1]),
        "rsi":          lat.get("rsi_14", 50),
        "adx":          lat.get("adx", 20),
        "regime":       None,
        "regime_conf":  None,
        "source":       "rule",
        "bias":         "NEUTRAL",
        "conf":         "Low confidence",
        "confidence":   0.5,
        "xgb_signal":   None,
        "lgb_signal":   None,
        "reasons":      [],
        "asset_class":  None,
    }

    # Resolve asset class for display
    from src.data.models import ALL_SYMBOLS
    info = ALL_SYMBOLS.get(sym)
    if info:
        result["asset_class"] = info.asset_class.value

    # Try asset-class-aware router first
    router = get_asset_router()
    if router:
        try:
            feat_series = features_df.iloc[-1]
            pred = router.predict(sym, feat_series)
            if pred:
                sig_map = {-1: "SELL", 0: "HOLD", 1: "BUY"}
                from src.prediction.labels import Signal
                bias = sig_map.get(pred.signal.value, "NEUTRAL")
                if pred.confidence >= 0.65:
                    bias = "STRONG " + bias if bias in ("BUY", "SELL") else bias

                result.update({
                    "bias":        bias,
                    "conf":        f"{pred.confidence:.0%}",
                    "confidence":  pred.confidence,
                    "regime":      pred.regime.value,
                    "regime_conf": pred.regime_confidence,
                    "xgb_signal":  pred.xgb_signal.name,
                    "lgb_signal":  pred.lgb_signal.name,
                    "source":      f"asset_model_{result['asset_class'] or 'global'}",
                    "reasons": [
                        f"Asset model ({result['asset_class']}): "
                        f"XGB={pred.xgb_signal.name} LGB={pred.lgb_signal.name}",
                        f"Regime: {pred.regime.value} | "
                        f"Conf: {pred.confidence:.0%} | "
                        f"B:{pred.buy_prob:.0%} H:{pred.hold_prob:.0%} S:{pred.sell_prob:.0%}",
                    ],
                })
                return result
        except Exception:
            pass

    # Try global ensemble fallback
    if ensemble and regime_detector:
        try:
            feat_series  = features_df.iloc[-1]
            ohlcv_cols   = {"open", "high", "low", "close", "volume"}
            feature_cols = [c for c in features_df.columns
                            if c not in ohlcv_cols and c in ensemble.feature_cols]
            feat_filtered = feat_series[feature_cols]
            regime_res    = regime_detector.detect(feat_series)
            pred          = ensemble.predict_latest(feat_filtered, regime_result=regime_res)
            from src.prediction.labels import Signal
            sig_map = {-1: "SELL", 0: "HOLD", 1: "BUY"}
            bias    = sig_map.get(pred.signal.value, "NEUTRAL")
            if pred.confidence >= 0.65:
                bias = "STRONG " + bias if bias in ("BUY", "SELL") else bias
            result.update({
                "bias":        bias,
                "conf":        f"{pred.confidence:.0%}",
                "confidence":  pred.confidence,
                "regime":      regime_res.regime.value,
                "regime_conf": regime_res.confidence,
                "xgb_signal":  pred.xgb_signal.name,
                "lgb_signal":  pred.lgb_signal.name,
                "source":      "global_ensemble",
                "reasons": [
                    f"Global ensemble: XGB={pred.xgb_signal.name} LGB={pred.lgb_signal.name}",
                    f"Regime: {regime_res.regime.value} | Conf: {pred.confidence:.0%}",
                ],
            })
            return result
        except Exception:
            pass

    # Rule-based fallback
    bias, conf, reasons = get_overall_bias(lat)
    regime_str = None
    if regime_detector:
        try:
            r = regime_detector.detect(features_df.iloc[-1])
            regime_str = r.regime.value
        except Exception:
            pass

    result.update({
        "bias":    bias,
        "conf":    conf,
        "regime":  regime_str,
        "reasons": reasons,
        "source":  "rule",
    })

    # Apply event engine adjustments to final signal
    try:
        ee = get_event_engine()
        ni = get_news_intelligence()
        if ee and ni:
            articles = ni.get_all_linked(max_age=120)
            events   = ee.detect_all(articles=articles)
            if events:
                adjusted = ee.adjust_signal(
                    symbol     = sym,
                    bias       = result["bias"],
                    confidence = result["confidence"],
                    events     = events,
                )
                result["bias"]       = adjusted.adjusted_bias
                result["confidence"] = adjusted.adjusted_confidence
                result["conf"]       = f"{adjusted.adjusted_confidence:.0%}"

                if adjusted.event_warnings:
                    result["reasons"] = adjusted.event_warnings + result["reasons"]
                if adjusted.trade_verdict in ("AVOID", "CAUTION"):
                    result["reasons"].insert(
                        0,
                        f"🌍 Event verdict: {adjusted.trade_verdict} "
                        f"(dampening {adjusted.event_dampening:.0%})"
                    )
                result["event_verdict"]   = adjusted.trade_verdict
                result["event_dampening"] = adjusted.event_dampening
    except Exception:
        pass  # event engine is best-effort

    return result


def get_hybrid_signal(
    sym:         str,
    df,
    features_df,
    ensemble=None,
    regime_detector=None,
) -> dict:
    """
    Compute hybrid signal fusing technical + news + events + behavior.
    Falls back gracefully through each layer if a component fails.
    Returns same structure as get_signal_with_ensemble() for compatibility.
    """
    # ── Step 1: Get technical signal first (needed as base) ────────────────
    tech_result = get_signal_with_ensemble(sym, df, features_df, ensemble, regime_detector)
    technical_bias = tech_result.get("bias", "NEUTRAL")
    technical_conf = tech_result.get("confidence", 0.5)

    # ── Step 2: Try full hybrid fusion ────────────────────────────────────
    he = get_hybrid_engine()
    if he is None:
        return tech_result   # fall back to technical only

    try:
        from src.analysis.hybrid_engine import HybridSignal

        # Gather pre-computed inputs (avoid re-fetching)
        news_sent    = None
        event_summ   = None
        behav_read   = None

        # News sentiment for this symbol
        ni = get_news_intelligence()
        if ni:
            try:
                sym_news  = ni.get_symbol_news(sym, max_age=120, top_n=5)
                news_sent = sym_news.get("sentiment", {})
            except Exception:
                pass

        # Event summary (global)
        ee = get_event_engine()
        if ee:
            try:
                articles   = ni.get_all_linked(max_age=120) if ni else []
                events     = ee.detect_all(articles=articles)
                event_summ = ee.get_event_summary(events)
            except Exception:
                pass

        # Behavior reading (current time)
        bm = get_behavior_model()
        if bm:
            try:
                behav_read = bm.get_current_reading()
            except Exception:
                pass

        # Run hybrid fusion
        feat_series = features_df.iloc[-1] if features_df is not None and not features_df.empty else None
        hybrid = he.predict(
            symbol           = sym,
            features         = feat_series,
            df               = df,
            technical_bias   = technical_bias,
            technical_conf   = technical_conf,
            news_sentiment   = news_sent,
            event_summary    = event_summ,
            behavior_reading = behav_read,
        )

        # Build return dict compatible with existing code
        lat = features_df.iloc[-1].to_dict() if features_df is not None and not features_df.empty else {}
        result = {
            "sym":              sym,
            "price":            float(df["close"].iloc[-1]) if df is not None and not df.empty else 0,
            "rsi":              lat.get("rsi_14", 50),
            "adx":              lat.get("adx", 20),
            "regime":           tech_result.get("regime"),
            "regime_conf":      tech_result.get("regime_conf"),
            "asset_class":      tech_result.get("asset_class"),
            # Hybrid outputs
            "bias":             hybrid.final_bias,
            "conf":             f"{hybrid.final_confidence:.0%}",
            "confidence":       hybrid.final_confidence,
            "source":           "hybrid",
            "xgb_signal":       tech_result.get("xgb_signal"),
            "lgb_signal":       tech_result.get("lgb_signal"),
            "reasons":          hybrid.reasoning,
            "warnings":         hybrid.warnings,
            "opportunities":    hybrid.opportunities,
            # Hybrid-specific extras
            "hybrid_score":     hybrid.final_score,
            "trade_verdict":    hybrid.trade_verdict,
            "weights":          hybrid.weights_used,
            "session_label":    hybrid.session_label,
            "news_count":       hybrid.news_article_count,
            "event_count":      hybrid.active_event_count,
            # Component scores for display
            "tech_score":       hybrid.technical.weighted,
            "news_score":       hybrid.news.weighted,
            "event_score":      hybrid.events.weighted,
            "behav_score":      hybrid.behavior.weighted,
            # Raw tech result for fallback features
            "_tech_result":     tech_result,
        }
        return result

    except Exception as e:
        # Never crash the dashboard — fall back to technical signal
        logger.warning(f"Hybrid engine failed for {sym}: {e}")
        tech_result["source"] = "technical_fallback"
        return tech_result



def get_action_signal(
    sym: str,
    df,
    features_df,
    ensemble=None,
    regime_detector=None,
) -> dict:
    """
    Full pipeline: PredictionEngine -> ActionEngine -> ActionDecision dict.
    Falls back through hybrid -> technical -> rule-based if any layer fails.
    """
    pe = get_prediction_engine()
    ae = get_action_engine()

    if pe is None or ae is None:
        return get_hybrid_signal(sym, df, features_df, ensemble, regime_detector)

    try:
        feat_series = (
            features_df.iloc[-1]
            if features_df is not None and not features_df.empty
            else None
        )
        lat = feat_series.to_dict() if feat_series is not None else {}
        price = float(df["close"].iloc[-1]) if df is not None and not df.empty else 0.0
        atr_pct = float(lat.get("atr_pct", 0.015) or 0.015)

        regime = None
        if regime_detector and feat_series is not None:
            try:
                r = regime_detector.detect(feat_series)
                regime = r.regime.value
            except Exception:
                pass

        news_result = None
        ni = get_news_intelligence()
        if ni:
            try:
                nr = ni.get_symbol_news(sym, max_age=120, top_n=8)
                news_result = nr.get("sentiment", {})
            except Exception:
                pass

        event_summary = None
        ee = get_event_engine()
        if ee and ni:
            try:
                articles = ni.get_all_linked(max_age=120)
                events = ee.detect_all(articles=articles)
                event_summary = ee.get_event_summary(events)
            except Exception:
                pass

        behavior_reading = None
        bm = get_behavior_model()
        if bm:
            try:
                behavior_reading = bm.get_current_reading()
            except Exception:
                pass

        tech_result = get_signal_with_ensemble(sym, df, features_df, ensemble, regime_detector)

        prediction = pe.predict(
            symbol=sym,
            features=feat_series,
            df=df,
            technical_bias=tech_result.get("bias"),
            technical_conf=tech_result.get("confidence", 0.5),
            news_result=news_result,
            event_summary=event_summary,
            behavior_reading=behavior_reading,
            regime_str=regime,
        )

        decision = ae.decide(prediction, current_price=price, atr_pct=atr_pct)

        return {
            "sym": sym,
            "price": price,
            "rsi": lat.get("rsi_14", 50),
            "adx": lat.get("adx", 20),
            "regime": prediction.regime,
            "regime_conf": None,
            "asset_class": prediction.asset_class,
            "bias": decision.signal,
            "conf": f"{decision.confidence:.0%}",
            "confidence": decision.confidence,
            "action": decision.action,
            "source": "prediction_engine",
            "xgb_signal": tech_result.get("xgb_signal"),
            "lgb_signal": tech_result.get("lgb_signal"),
            "reasons": list(decision.reasoning.values()),
            "warnings": decision.warnings,
            "opportunities": decision.opportunities,
            "sl_pct": decision.sl_pct,
            "target_pct": decision.target_pct,
            "risk_reward": decision.risk_reward,
            "hold_type": decision.hold_type,
            "asset_trust": decision.asset_trust,
            "learning_pid": decision.learning_pid,
            "reasoning": decision.reasoning,
            "tech_score": prediction.technical.weighted,
            "cross_asset_score": prediction.cross_asset.weighted,
            "news_score": prediction.news.weighted,
            "event_score": prediction.events.weighted,
            "behav_score": prediction.behavior.weighted,
            "raw_score": prediction.raw_score,
            "weights": prediction.weights_used,
        }

    except Exception as e:
        logger.warning(f"PredictionEngine failed for {sym}: {e}")
        return get_hybrid_signal(sym, df, features_df, ensemble, regime_detector)


def explain_rsi(v: float) -> tuple:
    if v >= 70:  return "OVERBOUGHT",  f"RSI {v:.0f} → Overbought. Pullback likely. Avoid buying."
    if v <= 30:  return "OVERSOLD",    f"RSI {v:.0f} → Oversold. Bounce likely. Possible buy."
    if v >= 55:  return "BULLISH",     f"RSI {v:.0f} → Bullish zone. Positive momentum."
    if v <= 45:  return "BEARISH",     f"RSI {v:.0f} → Bearish zone. Negative momentum."
    return                "NEUTRAL",   f"RSI {v:.0f} → Neutral. No strong momentum signal."


def explain_macd(hist: float, chg: float) -> tuple:
    if hist > 0 and chg > 0:  return "BULLISH",    "MACD histogram positive & rising → Bullish momentum strengthening."
    if hist > 0 and chg < 0:  return "WEAKENING",  "MACD positive but falling → Bullish momentum weakening."
    if hist < 0 and chg < 0:  return "BEARISH",    "MACD negative & falling → Bearish momentum strengthening."
    if hist < 0 and chg > 0:  return "RECOVERING", "MACD negative but rising → Bearish momentum weakening."
    return                            "NEUTRAL",    "MACD neutral."


def explain_bb(v: float) -> tuple:
    if v >= 1.0: return "OVERBOUGHT", "Price at/above upper Bollinger Band → Mean reversion likely."
    if v <= 0.0: return "OVERSOLD",   "Price at/below lower Bollinger Band → Bounce likely."
    if v >= 0.7: return "BULLISH",    "Price in upper Bollinger half → Bullish pressure."
    if v <= 0.3: return "BEARISH",    "Price in lower Bollinger half → Bearish pressure."
    return               "NEUTRAL",   "Price in middle of Bollinger Bands → No strong signal."


def explain_adx(adx: float, di_diff: float) -> tuple:
    trend = "bullish" if di_diff > 0 else "bearish"
    if adx >= 30: return f"STRONG {trend.upper()}", f"ADX {adx:.0f} → Strong {trend} trend. Trend-following works well."
    if adx >= 20: return f"MODERATE {trend.upper()}", f"ADX {adx:.0f} → Moderate {trend} trend forming."
    return                "RANGING",  f"ADX {adx:.0f} → Ranging market. Avoid trend trades."


def get_overall_bias(features: dict) -> tuple:
    score, reasons = 0, []
    rsi = features.get("rsi_14", 50)
    if rsi < 35:   score += 2; reasons.append(f"RSI oversold ({rsi:.0f}) → bullish")
    elif rsi > 65: score -= 2; reasons.append(f"RSI overbought ({rsi:.0f}) → bearish")
    elif rsi > 55: score += 1; reasons.append(f"RSI bullish zone ({rsi:.0f})")
    elif rsi < 45: score -= 1; reasons.append(f"RSI bearish zone ({rsi:.0f})")

    mh = features.get("macd_hist", 0)
    mc = features.get("macd_hist_chg", 0)
    if mh > 0 and mc > 0: score += 2; reasons.append("MACD bullish momentum")
    elif mh < 0 and mc < 0: score -= 2; reasons.append("MACD bearish momentum")

    bb = features.get("bb_pct_b", 0.5)
    if bb < 0.1:   score += 1; reasons.append("Price at lower Bollinger Band (bounce zone)")
    elif bb > 0.9: score -= 1; reasons.append("Price at upper Bollinger Band (resistance)")

    e9  = features.get("ema9_pct", 0)
    e50 = features.get("ema50_pct", 0)
    if e9 > 0 and e50 > 0:   score += 2; reasons.append("Price above EMA9 & EMA50 (bullish)")
    elif e9 < 0 and e50 < 0: score -= 2; reasons.append("Price below EMA9 & EMA50 (bearish)")

    adx = features.get("adx", 20)
    if adx > 25: reasons.append(f"Strong trend (ADX={adx:.0f}) — trend signals reliable")

    if score >= 3:    return "STRONG BUY",  "High conviction", reasons
    elif score >= 1:  return "BUY",         "Moderate",        reasons
    elif score <= -3: return "STRONG SELL", "High conviction", reasons
    elif score <= -1: return "SELL",        "Moderate",        reasons
    return                   "NEUTRAL",     "Low confidence",  reasons


def normalise_action(bias: str, confidence: str = "Moderate") -> str:
    bias_u = (bias or "").upper()
    conf_u = (confidence or "").upper()
    if "BUY" in bias_u:
        return "BUY" if "HIGH" in conf_u or "STRONG" in bias_u else "HOLD"
    if "SELL" in bias_u:
        return "SELL" if "HIGH" in conf_u or "STRONG" in bias_u else "WAIT"
    return "WAIT"


def build_action_summary(bias: str, confidence: str, reasons: list[str]) -> tuple[str, str]:
    action = normalise_action(bias, confidence)
    lead = {
        "BUY": "Buy bias is supported by momentum and trend.",
        "HOLD": "Hold for now, but stay with the existing trend.",
        "SELL": "Sell or avoid fresh longs because weakness is building.",
        "WAIT": "Wait for a clearer setup before taking a trade.",
    }[action]
    reason_text = " ".join(reasons[:2]) if reasons else "Signals are mixed right now."
    return action, f"{lead} {reason_text}"


def render_quick_take(action: str, summary: str) -> None:
    tone = {
        "BUY": st.success,
        "HOLD": st.info,
        "SELL": st.error,
        "WAIT": st.warning,
    }.get(action, st.info)
    tone(f"Quick take: {action} - {summary}")


def crude_action_summary(pred, tech: dict, sentiment: dict) -> tuple[str, str]:
    if pred.direction == "GAP_UP" and pred.confidence >= 0.6:
        action = "BUY"
    elif pred.direction == "GAP_DOWN" and pred.confidence >= 0.6:
        action = "SELL"
    else:
        action = "WAIT"

    rsi = tech.get("rsi", 50)
    news_label = sentiment.get("label", "neutral")
    if action == "BUY":
        summary = (
            f"Buy bias for crude because the opening model points up with {pred.confidence:.0%} confidence, "
            f"RSI is {rsi:.0f}, and news tone is {news_label}."
        )
    elif action == "SELL":
        summary = (
            f"Sell bias for crude because the opening model points down with {pred.confidence:.0%} confidence, "
            f"RSI is {rsi:.0f}, and news tone is {news_label}."
        )
    else:
        summary = (
            f"Wait on crude because conviction is limited at {pred.confidence:.0%}, "
            f"RSI is {rsi:.0f}, and confirmation is still needed."
        )
    return action, summary


