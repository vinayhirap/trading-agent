def regime_badge(regime_str: str) -> str:
    if not regime_str:
        return ""
    icon  = REGIME_ICONS.get(regime_str, "")
    css   = REGIME_CSS.get(regime_str, "")
    label = regime_str.replace("_", " ").title()
    return f'<span class="{css}">{icon} {label}</span>'


