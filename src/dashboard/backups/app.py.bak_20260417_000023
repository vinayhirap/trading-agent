def get_tradingview_symbol(symbol: str) -> str:
    if symbol in TRADINGVIEW_SYMBOL_MAP:
        return TRADINGVIEW_SYMBOL_MAP[symbol]

    if symbol in NSE_SYMBOLS:
        return f"NSE:{symbol}"
    if symbol in FOREX_SYMBOLS:
        return f"FX_IDC:{symbol}"
    if symbol in CRYPTO_SYMBOLS:
        return f"BINANCE:{symbol}USDT"

    return symbol


def can_use_tradingview_widget(symbol: str) -> tuple[bool, str]:
    if symbol in TRADINGVIEW_EMBED_SUPPORTED:
        return True, ""

    if symbol in NSE_SYMBOLS or symbol in ("NIFTY50", "BANKNIFTY", "NIFTYBANK", "NIFTYIT", "SENSEX"):
        return False, "TradingView embed blocks many Indian exchange symbols in widgets, so this chart is shown in native mode."

    if symbol in MCX_SYMBOLS or symbol in ("GOLD", "SILVER", "CRUDEOIL"):
        return False, "TradingView embed blocks these commodity contracts in widgets, so this chart is shown in native mode."

    return False, "This symbol is not reliably available in the embedded TradingView widget, so native mode is used."


