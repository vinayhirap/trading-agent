def format_price_with_unit(symbol: str, price: float, usdinr: float = 84.0) -> str:
    if symbol in ("BTC", "ETH", "SOL", "MATIC", "BNB", "XRP", "ADA", "DOGE"):
        return f"₹{price * usdinr:,.0f}"

    if symbol == "GOLD":
        # MCX gold price is quoted in INR per 10g; yfinance fallback is USD/troy oz.
        if price < 10000:
            price = price * usdinr * 31.1035 / 10
        return f"₹{price:,.0f} /10g"

    if symbol == "SILVER":
        if price < 1000:
            price = price * usdinr * 31.1035 / 1000
        return f"₹{price:,.0f} /g"

    if symbol == "CRUDEOIL":
        if price < 1000:
            price = price * usdinr
        return f"₹{price:,.0f} /bbl"

    if symbol in ("COPPER", "NATURALGAS"):
        if price < 1000:
            price = price * usdinr
        return f"₹{price:,.0f}"

    if symbol in ("NIFTY50", "BANKNIFTY", "SENSEX", "NIFTYMID", "NIFTYIT"):
        return f"{price:,.2f} pts"

    return f"₹{price:,.2f}"


