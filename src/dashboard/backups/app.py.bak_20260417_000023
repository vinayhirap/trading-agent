                    def resolve_symbol(raw_value):
                        raw = str(raw_value).strip()
                        if not raw:
                            return None
                        norm = raw.upper()
                        if norm in NSE_SYMBOLS:
                            return norm
                        norm_clean = norm.replace(".NS", "").replace(" ", "").replace("&", "AND").replace("/", "").replace("-", "").replace(".", "")
                        if norm_clean in NSE_SYMBOLS:
                            return norm_clean
                        for ticker, info in NSE_SYMBOLS.items():
                            info_name = info.name.upper().replace(" ", "").replace("&", "AND").replace(".", "")
                            if norm_clean == info_name or norm_clean in info_name or info_name in norm_clean:
                                return ticker
                        return norm

                    holdings = []
